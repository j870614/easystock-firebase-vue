rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── 共用函式 ──────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isOwner() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner';
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuth() && (
        request.auth.uid == 'j1LNiIEkZY61JDVytWFuQWfogB3' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['owner', 'admin']
      );
    }

    function isStaff() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['owner', 'admin', 'hallLead', 'staff'];
    }

    function permissionsPath() {
      return /databases/$(database)/documents/settings/permissions;
    }

    function defaultPermissionRoles(permissionKey) {
      return permissionKey == 'inventory.write' ? ['owner', 'admin', 'hallLead', 'staff']
        : permissionKey == 'dashboard.view' ? ['owner', 'admin', 'hallLead', 'staff']
        : permissionKey == 'transactions.view' ? ['owner', 'admin', 'hallLead', 'staff']
        : permissionKey == 'transactions.write' ? ['owner', 'admin', 'hallLead', 'staff']
        : permissionKey == 'reports.view' ? ['owner', 'admin', 'hallLead', 'staff']
        : permissionKey == 'products.write' ? ['owner', 'admin', 'hallLead']
        : permissionKey == 'products.delete' ? ['owner']
        : permissionKey == 'import.data' ? ['owner', 'admin', 'hallLead']
        : permissionKey == 'locations.write' ? ['owner', 'admin']
        : ['owner'];
    }

    function hasPermission(permissionKey) {
      return isOwner()
        || (
          isAuth()
          && (
            (
              exists(permissionsPath())
              && userRole() in get(permissionsPath()).data.roles.get(permissionKey, defaultPermissionRoles(permissionKey))
            )
            || (
              !exists(permissionsPath())
              && userRole() in defaultPermissionRoles(permissionKey)
            )
          )
        );
    }

    // ── users 集合 ────────────────────────────────────────────
    // - 任何已登入使用者可讀取自己的文件
    // - 只有系統總管可以寫入或變更 role 欄位
    match /users/{uid} {
      allow read: if isAuth() && (request.auth.uid == uid || isAdmin());

      // 自己新增自己（首次登入）
      allow create: if isAuth() && request.auth.uid == uid
                    && request.resource.data.role == 'pending';

      // 自己只能更新個人資料，不可自行調整 security / role 等安全欄位。
      // pending 首次送出審核資料時，可一併提交 dutyId / dutyName；審核後不可自行更改職稱。
      allow update: if isAuth() && request.auth.uid == uid
                    && request.resource.data.role == resource.data.role
                    && (
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                        'dharmaName',
                        'secularName',
                        'profileSubmitted',
                      ])
                      || (
                        resource.data.role == 'pending'
                        && resource.data.get('profileSubmitted', false) != true
                        && request.resource.data.get('profileSubmitted', false) == true
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                          'dharmaName',
                          'secularName',
                          'dutyId',
                          'dutyName',
                          'profileSubmitted',
                        ])
                      )
                    );

      // 系統總管可更新任何欄位（包含 role）
      allow update: if isOwner();

      // 禁止任何人刪除使用者文件
      allow delete: if false;
    }

    match /users/{uid}/passkeyDeviceRequests/{requestId} {
      allow read: if isAuth() && (request.auth.uid == uid || isOwner());
      allow write: if false;
    }

    match /users/{uid}/passkeys/{passkeyId} {
      allow read: if isAuth() && (request.auth.uid == uid || isOwner());
      allow write: if false;
    }

    // ── locations 集合 ────────────────────────────────────────
    match /locations/{locationId} {
      allow read:   if isStaff();
      allow create: if hasPermission('locations.write');
      allow update: if hasPermission('locations.write');
      allow delete: if isOwner();
    }

    // ── halls 集合 ────────────────────────────────────────────
    match /halls/{hallId} {
      allow read:   if isStaff();
      allow create: if hasPermission('locations.write');
      allow update: if hasPermission('locations.write');
      allow delete: if isOwner();
    }

    // ── products 集合 ─────────────────────────────────────────
    match /products/{productId} {
      allow read:   if isStaff();
      allow create: if hasPermission('products.write');
      allow update: if hasPermission('products.write');
      allow delete: if hasPermission('products.delete');
    }

    // ── productPlacements 集合 ───────────────────────────────
    match /productPlacements/{placementId} {
      allow read:   if isStaff();
      allow create: if hasPermission('products.write');
      allow update: if hasPermission('products.write');
      allow delete: if hasPermission('products.delete');
    }

    // ── stocks 集合（庫存快取）────────────────────────────────
    // 寫入只透過 Firestore Transaction（Client SDK）或 Cloud Function
    match /stocks/{stockId} {
      allow read:   if isStaff();
      // Staff 可以寫（因為入出庫使用 Client SDK runTransaction）
      allow write:  if hasPermission('inventory.write');
    }

    // ── transactions 集合 ─────────────────────────────────────
    match /transactions/{txId} {
      allow read:   if isStaff();
      // Staff 可以新增、修改、刪除交易紀錄
      allow create: if hasPermission('inventory.write')
                    && request.resource.data.operator.uid == request.auth.uid;
      allow update: if hasPermission('transactions.write');
      allow delete: if hasPermission('transactions.write');
    }

    // ── settings 集合（系統設定）─────────────────────────────
    match /settings/{docId} {
      allow read:   if isAuth();
      allow write:  if isOwner();
    }

    // ── duties 集合（執事選項）───────────────────────────
    // 所有已登入用戶可讀（PendingView 需要），只有系統總管可管理
    match /duties/{dutyId} {
      allow read:  if isAuth();
      allow write: if isOwner();
    }

  }
}
